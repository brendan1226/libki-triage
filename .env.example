# Optional: GitHub personal access token.
# Unauthenticated requests work but hit a 60-requests/hour rate limit.
# Authenticated requests get 5000/hour. Scopes needed: public_repo (read-only).
LIBKI_TRIAGE_GITHUB_TOKEN=

# Where to store the SQLite database. Default: ./data/libki-triage.db
# LIBKI_TRIAGE_DB_PATH=./data/libki-triage.db
