# Optional: GitHub personal access token.
# Unauthenticated requests work but hit a 60-requests/hour rate limit.
# Authenticated requests get 5000/hour. Scopes needed: public_repo (read-only).
LIBKI_TRIAGE_GITHUB_TOKEN=

# Required for the `classify` command and the /search web UI's AI verdicts.
# Get one from https://console.anthropic.com/settings/keys
# Without this, `search` still works (returns ranked similarity only); `classify`
# and the web UI's verdict column will be disabled.
LIBKI_TRIAGE_ANTHROPIC_API_KEY=

# Where to store the SQLite database. Default: ./data/libki-triage.db
# LIBKI_TRIAGE_DB_PATH=./data/libki-triage.db

# Embedding model for semantic search. Default: BAAI/bge-small-en-v1.5 (384 dims, ~90MB).
# Alternatives: BAAI/bge-base-en-v1.5 (768 dims, better quality, ~440MB), sentence-transformers/all-MiniLM-L6-v2.
# LIBKI_TRIAGE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Claude model for verdict classification. Default: claude-opus-4-6.
# For cost/speed, can set to claude-haiku-4-5 or claude-sonnet-4-6.
# LIBKI_TRIAGE_CLASSIFICATION_MODEL=claude-opus-4-6
